{
  "name": "payment-retry-worker",
  "version": "1.0.0",
  "description": "Consumes payment.retry.requested events and retries payment initiation with bounded, delayed retries, reconciling the order's final state via Order Service.",
  "main": "dist/worker.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/worker.js",
    "dev": "ts-node-dev --respawn --transpile-only src/worker.ts",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@ecommerce/shared": "*",
    "express": "^4.19.2",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  }
}
